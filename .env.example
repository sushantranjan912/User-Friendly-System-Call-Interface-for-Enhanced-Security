# Security: Generate strong secrets for production deployments
# Run: python -c "import secrets; print(secrets.token_hex(32))"

# Session and cookie signing key (required, minimum 32 characters)
SECRET_KEY=your_secure_secret_key_here_minimum_32_characters

# JWT token signing key (required, minimum 32 characters)
JWT_SECRET_KEY=your_secure_jwt_key_here_minimum_32_characters

# File encryption key (required, minimum 32 characters)
ENCRYPTION_KEY=your_secure_encryption_key_here_minimum_32_characters

# Optional: Database path (defaults to database/database.db)
# DATABASE_PATH=database/database.db
